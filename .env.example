# LLM (default: Ollama)
LLM_PROVIDER=ollama
LLM_MODEL=qwen3.5:latest
OLLAMA_BASE_URL=http://localhost:11434/v1

# Future providers (uncomment when needed)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Agent output validation retries (how many times to retry if LLM output fails schema validation)
AGENT_RETRIES=3

# Search / tools
TAVILY_API_KEY=

# FastAPI server
API_HOST=0.0.0.0
API_PORT=8000

# SQLite database path (relative to project root)
DB_PATH=./data/sessions.db

# CORS — frontend origin (used in production; localhost:3000 always allowed)
FRONTEND_URL=

# Next.js frontend (set in web/.env.local for production)
# NEXT_PUBLIC_API_URL=http://localhost:8000
